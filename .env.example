# Slack bot token (xoxb-...). Needs scopes: users:read, users:read.email, users.profile:read
SLACK_BOT_TOKEN=xoxb-your-token-here

# --- Google auth -----------------------------------------------------------
# How to authenticate to Google Sheets: "service_account" (default) or "oauth".
#   service_account: share the sheet with the service-account email. Simplest, but
#                    blocked if your org forbids external sharing.
#   oauth:           act as a real user who already has access (e.g. via a Google
#                    Group / shared folder). Sidesteps external-sharing limits.
GOOGLE_AUTH_MODE=service_account

# Used when GOOGLE_AUTH_MODE=service_account: path to the service-account JSON key file
GOOGLE_CREDENTIALS_FILE=./service-account.json

# Used when GOOGLE_AUTH_MODE=oauth:
#   GOOGLE_OAUTH_CLIENT_FILE: OAuth client-secrets JSON (Desktop app) you downloaded
#   GOOGLE_OAUTH_TOKEN_FILE:  where the authorized-user token is stored (created by
#                             `python -m slack_sheet_sync.google_oauth_setup`)
GOOGLE_OAUTH_CLIENT_FILE=./oauth-client.json
GOOGLE_OAUTH_TOKEN_FILE=./oauth-token.json

# The spreadsheet id (the long string in the sheet URL: /d/<THIS>/edit)
SPREADSHEET_ID=your-spreadsheet-id

# Worksheet/tab name to write into (created if missing)
WORKSHEET_NAME=Members

# Opaque Slack custom-profile field id for "section" (looks like Xf0123ABCD).
# Find it once with: python -m slack_sheet_sync.find_field_id
SECTION_FIELD_ID=Xf0000000000

# How often to poll Slack, in seconds (default 300 = 5 min)
POLL_INTERVAL_SECONDS=300
